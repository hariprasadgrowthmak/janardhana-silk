{% schema %}
{
  "name": "KZ About Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "checkbox",
      "id": "show_decorative_bg",
      "label": "Show Decorative Background Shape",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quote",
      "label": "Show Floating Quote Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "quote_text",
      "label": "Quote Text",
      "default": "Comfort that feels like a hug."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Heading",
      "default": "Welcome to Koozy. A Little Happy Place."
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>We started Koozy with one simple thought: Why should nightwear and loungewear be boring?</p><p>From slow mornings to cozy nights, every piece feels like a gentle hug.</p>"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background Color",
      "default": "#FAFAFA"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#6A50A1"
    },
    {
      "type": "color",
      "id": "pink_color",
      "label": "Decorative Shape Color",
      "default": "#F4D7E8"
    },
    {
      "type": "color",
      "id": "peach_color",
      "label": "Subheading Background Color",
      "default": "#FEDEC3"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Heading Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Body Text Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable Fade Animation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Number",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Stat Label",
          "default": "Soft Cotton"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "KZ About Section",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}
<section 
  class="kz-about-section"
  style="
    background-color: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    --kz-primary: {{ section.settings.primary_color }};
    --kz-pink: {{ section.settings.pink_color }};
    --kz-peach: {{ section.settings.peach_color }};
    --kz-foreground: {{ section.settings.foreground_color }};
    --kz-muted: {{ section.settings.muted_color }};
  "
>

  <div class="kz-about-container">
    <div class="kz-about-grid">

      <!-- LEFT IMAGE -->
      <div class="kz-about-image-wrap {% if section.settings.enable_animation %}kz-about-fade{% endif %}">
        
        {% if section.settings.show_decorative_bg %}
        <div class="kz-about-bg-shape"></div>
        {% endif %}

        <div class="kz-about-image-box">
          {% if section.settings.image != blank %}
            <img 
              src="{{ section.settings.image | image_url: width: 1000 }}"
              alt="{{ section.settings.image.alt | escape }}"
              class="kz-about-image"
            >
          {% endif %}
        </div>

        {% if section.settings.show_quote %}
        <div class="kz-about-quote">
          <div class="kz-about-quote-mark">"</div>
          <p class="kz-about-quote-text">
            {{ section.settings.quote_text }}
          </p>
        </div>
        {% endif %}
      </div>

      <!-- RIGHT CONTENT -->
      <div class="kz-about-content {% if section.settings.enable_animation %}kz-about-fade{% endif %}">
        
        {% if section.settings.subheading != blank %}
        <span class="kz-about-subheading">
          {{ section.settings.subheading }}
        </span>
        {% endif %}

        {% if section.settings.heading != blank %}
        <h2 class="kz-about-heading">
          {{ section.settings.heading }}
        </h2>
        {% endif %}

        {% if section.settings.content != blank %}
        <div class="kz-about-text">
          {{ section.settings.content }}
        </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
        <div class="kz-about-stats">
          {% for block in section.blocks %}
            <div class="kz-about-stat" {{ block.shopify_attributes }}>
              <span class="kz-about-stat-number">
                {{ block.settings.stat_number }}
              </span>
              <span class="kz-about-stat-label">
                {{ block.settings.stat_label }}
              </span>
            </div>
          {% endfor %}
        </div>
        {% endif %}

      </div>

    </div>
  </div>

  {% if section.settings.enable_animation %}
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      setTimeout(function() {
        document.querySelectorAll('.kz-about-fade')
          .forEach(el => el.classList.add('kz-about-visible'));
      }, 100);
    });
  </script>
  {% endif %}

</section>

<style>
.kz-about-section {
  position: relative;
}

.kz-about-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.kz-about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

@media (max-width: 768px) {
  .kz-about-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}

.kz-about-image-wrap {
  position: relative;
}

.kz-about-bg-shape {
  position: absolute;
  top: 20px;
  left: -20px;
  width: 100%;
  height: 100%;
  background: var(--kz-pink);
  opacity: 0.3;
  border-radius: 40px;
  z-index: 0;
}

.kz-about-image-box {
  position: relative;
  overflow: hidden;
  border-radius: 40px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  z-index: 1;
}

.kz-about-image {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.7s ease;
}

.kz-about-image:hover {
  transform: scale(1.05);
}

.kz-about-quote {
  position: absolute;
  bottom: -20px;
  right: -20px;
  background: #fff;
  padding: 20px;
  border-radius: 24px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  max-width: 200px;
  z-index: 2;
}

@media (max-width: 768px) {
  .kz-about-quote {
    display: none;
  }
}

.kz-about-quote-mark {
  font-size: 40px;
  color: var(--kz-primary);
}

.kz-about-quote-text {
  font-size: 14px;
  font-weight: 700;
  color: var(--kz-foreground);
}

.kz-about-subheading {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 999px;
  background: var(--kz-peach);
  color: var(--kz-primary);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.kz-about-heading {
  font-size: 42px;
  font-weight: 700;
  color: var(--kz-foreground);
  margin-bottom: 30px;
  line-height: 1.2;
}

@media (max-width: 768px) {
  .kz-about-heading {
    font-size: 32px;
  }
}

.kz-about-text {
  color: var(--kz-muted);
  font-size: 18px;
  line-height: 1.7;
}

.kz-about-text p {
  margin-bottom: 20px;
}

.kz-about-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  margin-top: 40px;
  padding-top: 30px;
  border-top: 1px solid #e5e5e5;
}

.kz-about-stat-number {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: var(--kz-primary);
  margin-bottom: 5px;
}

.kz-about-stat-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--kz-muted);
}

/* Animation */
.kz-about-fade {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.8s ease;
}

.kz-about-visible {
  opacity: 1;
  transform: translateY(0);
}
</style>